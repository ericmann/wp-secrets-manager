{
	"name": "displace-foundry/wp-secrets-manager",
	"description": "A standardized secrets management API for WordPress with automatic encryption.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Eric Mann",
			"email": "eric@eamann.com"
		}
	],
	"require": {
		"php": ">=7.2"
	},
	"require-dev": {
		"phpunit/phpunit": "^8.5 || ^9.6",
		"yoast/phpunit-polyfills": "^2.0 || ^4.0"
	},
	"scripts": {
		"test": "phpunit",
		"test-group": "phpunit --group",
		"coverage": "phpunit --coverage-clover=coverage/clover.xml --coverage-html=coverage/html"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
